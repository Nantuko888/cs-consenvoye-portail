function getSheet_(name) {
  const ss = SpreadsheetApp.getActiveSpreadsheet();
  const sh = ss.getSheetByName(name);
  if (!sh) throw new Error("Onglet introuvable : " + name);
  return sh;
}

function nextEventId_(sh) {
  const lastRow = sh.getLastRow();
  if (lastRow < 2) return 1;

  const ids = sh.getRange(2, 1, lastRow - 1, 1).getValues().flat();
  let maxId = 0;

  ids.forEach(v => {
    const n = Number(v);
    if (!isNaN(n) && n > maxId) maxId = n;
  });

  return maxId + 1;
}

function getEvenements_() {
  const sh = getSheet_("Evenements");
  const lastRow = sh.getLastRow();
  if (lastRow < 2) return [];

  const values = sh.getRange(2, 1, lastRow - 1, 6).getValues();

  return values
    .map(r => ({
      id: r[0],
      categorie: String(r[1] || "").trim(),
      titre: String(r[2] || "").trim(),
      date: String(r[3] || "").trim(),
      lieu: String(r[4] || "").trim(),
      description: String(r[5] || "").trim()
    }))
    .filter(e => e.titre);
}

function addEvenement_(params) {
  const sh = getSheet_("Evenements");

  const categorie = String(params.categorie || "").trim();
  const titre = String(params.titre || "").trim();
  const date = String(params.date || "").trim();
  const lieu = String(params.lieu || "").trim();
  const description = String(params.description || "").trim();

  if (!categorie || !titre) {
    throw new Error("Champs obligatoires manquants.");
  }

  const id = nextEventId_(sh);

  sh.appendRow([
    id,
    categorie,
    titre,
    date,
    lieu,
    description
  ]);

  return {
    ok: true,
    id: id
  };
}

function deleteEvenement_(params) {
  const sh = getSheet_("Evenements");
  const id = Number(params.id || 0);
  if (!id) throw new Error("ID manquant.");

  const lastRow = sh.getLastRow();
  if (lastRow < 2) throw new Error("Aucun événement.");

  const ids = sh.getRange(2, 1, lastRow - 1, 1).getValues().flat();

  for (let i = 0; i < ids.length; i++) {
    if (Number(ids[i]) === id) {
      sh.deleteRow(i + 2);
      return { ok: true, deletedId: id };
    }
  }

  throw new Error("Événement introuvable.");
}

function updateEvenement_(params) {
  const sh = getSheet_("Evenements");
  const id = Number(params.id || 0);
  if (!id) throw new Error("ID manquant.");

  const categorie = String(params.categorie || "").trim();
  const titre = String(params.titre || "").trim();
  const date = String(params.date || "").trim();
  const lieu = String(params.lieu || "").trim();
  const description = String(params.description || "").trim();

  if (!categorie || !titre) {
    throw new Error("Champs obligatoires manquants.");
  }

  const lastRow = sh.getLastRow();
  if (lastRow < 2) throw new Error("Aucun événement.");

  const ids = sh.getRange(2, 1, lastRow - 1, 1).getValues().flat();

  for (let i = 0; i < ids.length; i++) {
    if (Number(ids[i]) === id) {
      sh.getRange(i + 2, 1, 1, 6).setValues([[
        id,
        categorie,
        titre,
        date,
        lieu,
        description
      ]]);
      return { ok: true, updatedId: id };
    }
  }

  throw new Error("Événement introuvable.");
}


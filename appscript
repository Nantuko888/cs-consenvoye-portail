}


/** ================== COLORATION GOOGLE SHEETS (PlanningEvents) ================== **/
function colorPlanningEvents(){
  const ss = SpreadsheetApp.openById(SPREADSHEET_ID);

  const shEvents = ss.getSheetByName("PlanningEvents");
  const shCats = ss.getSheetByName("PlanningCategories");
  if(!shEvents || !shCats) throw new Error("Onglets introuvables (PlanningEvents / PlanningCategories)");

  // --- map category -> color (depuis PlanningCategories) ---
  const cats = shCats.getDataRange().getValues();
  if(cats.length < 2) throw new Error("PlanningCategories vide");
  const hCats = cats[0].map(x=>String(x).trim().toLowerCase());
  const iCat = hCats.indexOf("category");
  const iCol = hCats.indexOf("color");
  if(iCat === -1 || iCol === -1) throw new Error("Headers manquants dans PlanningCategories (category/color)");

  const map = new Map();
  for(let r=1;r<cats.length;r++){
    const cat = String(cats[r][iCat]||"").trim().toLowerCase();
    const col = String(cats[r][iCol]||"").trim();
    if(cat && col) map.set(cat, col);
  }

  // --- events range ---
  const lastRow = shEvents.getLastRow();
  const lastColAll = shEvents.getLastColumn();
  if(lastRow < 2) return;

  // on colore A:G max (7 colonnes) comme ton code
  const lastCol = Math.min(lastColAll, 7);

  // values pour trouver "category"
  const values = shEvents.getRange(1,1,lastRow,lastColAll).getValues();
  const headers = values[0].map(x => String(x).trim().toLowerCase());
  const idxCategory = headers.indexOf("category");
  if(idxCategory === -1) throw new Error("Colonne 'category' introuvable dans PlanningEvents");

  // on récupère les couleurs actuelles (IMPORTANT -> pas de null)
  const rng = shEvents.getRange(1,1,lastRow,lastCol);
  const bg = rng.getBackgrounds();
  const fg = rng.getFontColors();

  // ligne 1 = header : on touche pas
  for(let r=2; r<=lastRow; r++){
    const cat = String(values[r-1][idxCategory] || "").trim().toLowerCase();
    const color = map.get(cat);

    if(color){
      for(let c=1; c<=lastCol; c++){
        bg[r-1][c-1] = color;
        fg[r-1][c-1] = "#ffffff";
      }
    }
  }

  rng.setBackgrounds(bg);
  rng.setFontColors(fg);
}


function planningDeleteEvent_(e){
  const lock = LockService.getScriptLock();
  try{
    const ss = SpreadsheetApp.openById(SPREADSHEET_ID);

    const email = String(e?.parameter?.email || "").trim().toLowerCase();
    if(!email) return { ok:false, error:"email manquant" };

    const auth = authCheck_({ parameter:{ email } });
    if(!auth || auth.ok !== true || String(auth.role||"").toLowerCase() !== "admin"){
      return { ok:false, error:"Accès refusé (admin requis)" };
    }

    // priorité: event_id
    const event_id = String(e?.parameter?.event_id || e?.parameter?.id || "").trim();

    // fallback: date + title (+ start optionnel)
    const date = String(e?.parameter?.date || "").trim(); // YYYY-MM-DD
    const title = String(e?.parameter?.title || "").trim();
    const start = String(e?.parameter?.start || "").trim();

    if(!event_id && (!date || !title)){
      return { ok:false, error:"Paramètres manquants (event_id OU date/title)" };
    }

    lock.waitLock(15000);

    const sh = ss.getSheetByName(TAB_PLANNING_EVENTS);
    if(!sh) return { ok:false, error:`Onglet introuvable: ${TAB_PLANNING_EVENTS}` };

    const v = sh.getDataRange().getValues();
    if(v.length < 2) return { ok:true, deleted:0 };

    const headers = (v[0] || []).map(h => normHeader_(h));

    const findIndex_ = (keys) => {
      for(const k of keys){
        const i = headers.indexOf(k);
        if(i !== -1) return i;
      }
      return -1;
    };

    const iEventId = findIndex_(["event_id","eventid","id"]);
    const iDate = findIndex_(["date","jour","day"]);
    const iStart = findIndex_(["start","debut","heure_debut","heuredebut","hdebut"]);
    const iTitle = findIndex_(["title","titre","libelle","label","evenement","event"]);

    if(iEventId === -1 && (iDate === -1 || iTitle === -1)){
      return { ok:false, error:"Headers manquants: event_id/eventid OU (date + title/titre)" };
    }

    const normalizeDate_ = (val) => {
      if(val instanceof Date && !isNaN(val.getTime())){
        const y = val.getFullYear();
        const m = String(val.getMonth()+1).padStart(2,"0");
        const d = String(val.getDate()).padStart(2,"0");
        return `${y}-${m}-${d}`;
      }
      const s = String(val || "").trim();
      if(!s) return "";
      if(/^\d{4}-\d{2}-\d{2}$/.test(s)) return s;
      const m = s.match(/^(\d{1,2})\/(\d{1,2})\/(\d{4})$/); // dd/mm/yyyy
      if(m){
        const dd = String(m[1]).padStart(2,"0");
        const mm = String(m[2]).padStart(2,"0");
        const yy = m[3];
        return `${yy}-${mm}-${dd}`;
      }
      return s;
    };

    let deleted = 0;

    for(let r = v.length - 1; r >= 1; r--){
      let same = false;

      if(event_id && iEventId !== -1){
        const eid = String(v[r][iEventId] || "").trim();
        same = (eid === event_id);
      }else{
        const d = normalizeDate_(iDate !== -1 ? v[r][iDate] : "");
        const t = String(iTitle !== -1 ? v[r][iTitle] : "").trim();
        const s = String(iStart !== -1 ? v[r][iStart] : "").trim();

        same = (d === date && t === title && (start ? s === start : true));
      }

      if(same){
        sh.deleteRow(r + 1);
        deleted++;
        if(event_id) break; // une seule ligne
      }
    }

    return { ok:true, deleted };

  }catch(err){
    return { ok:false, error:String(err && err.message ? err.message : err) };
  }finally{
    try{ lock.releaseLock(); }catch(e){}
  }
}


function uploadTicketCarburant_(e){
  try{
    const folderRoot = DriveApp.getFolderById(FOLDER_TICKETS_CARBURANT);

    const p = (e && e.parameter) ? e.parameter : {};
    let body = {};
    if (e && e.postData && e.postData.contents) {
      try { body = JSON.parse(e.postData.contents); } catch(err){ body = {}; }
    }

    const vehicle = String(p.vehicle || body.vehicle || "").trim();
    const agent = String(p.agent || body.agent || "").trim();
    let imageB64 = String(p.image || body.image || "").trim();

    if (imageB64.includes(",")) imageB64 = imageB64.split(",").pop();

    if(!vehicle || !imageB64){
      return { ok:false, error:"Paramètres manquants (vehicle/image)" };
    }

    const now = new Date();
    const year = Utilities.formatDate(now, "Europe/Paris", "yyyy");

    const datePart = Utilities.formatDate(now, "Europe/Paris", "yyyy-MM-dd");
    const timePart = Utilities.formatDate(now, "Europe/Paris", "HH-mm-ss");

    const folders = folderRoot.getFoldersByName(year);
    const yearFolder = folders.hasNext() ? folders.next() : folderRoot.createFolder(year);

    const safeVeh = vehicle.replace(/[^\w-]/g, "_");
    const safeAgent = agent ? agent.replace(/[^\w-]/g, "_") : "agent";

    const filename = `${datePart}__${timePart}__${safeVeh}_${safeAgent}.jpg`;

    const bytes = Utilities.base64Decode(imageB64);
    const blob = Utilities.newBlob(bytes, "image/jpeg", filename);
    const file = yearFolder.createFile(blob).setName(filename);

    return {
      ok: true,
      fileId: file.getId(),
      url: file.getUrl(),
      name: file.getName(),
      year: yearFolder.getName()
    };

  }catch(err){
    return { ok:false, error:String(err && err.message ? err.message : err) };
  }
}

function listTicketsCarburant_(e){
  try{
    const folderRoot = DriveApp.getFolderById(FOLDER_TICKETS_CARBURANT);
    const year = String((e && e.parameter && e.parameter.year) || new Date().getFullYear());

    const yearFolders = folderRoot.getFoldersByName(year);
    if(!yearFolders.hasNext()) return { ok:true, year, count:0, files:[] };
    const yearFolder = yearFolders.next();

    const filesIt = yearFolder.getFiles();
    const all = [];
    const previewsByBase = {};

    while(filesIt.hasNext()){
      const f = filesIt.next();
      const name = String(f.getName() || "");
      const created = f.getDateCreated();
      const url = f.getUrl();
      const id = f.getId();

      if(name.endsWith("__preview.jpg")){
        const base = name.replace(/__preview\.jpg$/i, "");
        previewsByBase[base] = {
          id: id,
          url: url
        };
        continue;
      }

      all.push({
        id,
        name,
        url,
        created: created ? created.toISOString() : ""
      });
    }

    const out = [];

    all.forEach(file => {
      const name = file.name;

      let veh = "";
      let agent = "";
      let time = "";
      let dateFromName = "";

      const cleanExt = String(name).replace(/\.[a-z0-9]+$/i,"");

      if(cleanExt.includes("__")){
        const parts = cleanExt.split("__");
        if(parts.length >= 3){
          dateFromName = parts[0] || "";
          const timeRaw = parts[1] || "";
          const third = parts[2] || "";
          const v = third.split("_");
          veh = (v[0] || "").trim();
          agent = (v[1] || "").trim();

          const t = timeRaw.split("-");
          if(t.length >= 2){
            time = `${String(t[0]).padStart(2,"0")}:${String(t[1]).padStart(2,"0")}`;
          }
        }
      }

      const preview = previewsByBase[cleanExt] || null;

      out.push({
        id: file.id,
        name: file.name,
        url: file.url,
        created: file.created,
        veh,
        agent,
        time,
        dateFromName,
        previewId: preview ? preview.id : file.id,
        previewUrl: preview ? preview.url : file.url
      });
    });

    out.sort((a,b)=>{
      const ak = (a.dateFromName || "") + " " + (a.time || "");
      const bk = (b.dateFromName || "") + " " + (b.time || "");
      return bk.localeCompare(ak);
    });

    return { ok:true, year, count: out.length, files: out };

  }catch(err){
    return { ok:false, error:String(err && err.message ? err.message : err) };
  }
}

/**
 * GET: ?view=planning_years_list&nocache=1&callback=cb
 */
function getPlanningYear_(year, nocache){
  const cacheKey = `planning_year_v2_${year}`;
  try{
    if(!nocache){
      const cached = CacheService.getScriptCache().get(cacheKey);
      if(cached){
        return JSON.parse(cached);
      }
    }
  }catch(e){}

  const ss = SpreadsheetApp.openById(SPREADSHEET_ID);
  const sh = ss.getSheetByName(TAB_PLANNING_EVENTS);
  if(!sh) return { ok:false, error:`Onglet introuvable: ${TAB_PLANNING_EVENTS}` };

  const values = sh.getDataRange().getValues();
  if(values.length < 2){
    const out0 = { ok:true, year, events:[], updatedAt:new Date().toISOString() };
    try{ CacheService.getScriptCache().put(cacheKey, JSON.stringify(out0), 60*10); }catch(e){}
    return out0;
  }

  const headers = (values[0] || []).map(h => normHeader_(h));
  const idx = (k)=> headers.indexOf(k);

  const iEventId = idx("event_id");
  const iDate = idx("date");
  const iStart = idx("start");
  const iEnd = idx("end");
  const iTitle = idx("title");
  const iCat = idx("category");
  const iDetails = idx("details");
  const iLoc = idx("location");

  if(iDate === -1 || iTitle === -1){
    return {
      ok:false,
      error:`Headers manquants dans ${TAB_PLANNING_EVENTS} (au minimum: date, title). Reçu: ${headers.join(", ")}`
    };
  }

  const tz = Session.getScriptTimeZone();

  const toYmd_ = (v)=>{
    if(v instanceof Date && !isNaN(v.getTime())){
      return Utilities.formatDate(v, tz, "yyyy-MM-dd");
    }
    const s = String(v||"").trim();
    // déjà yyyy-mm-dd
    if(/^\d{4}-\d{2}-\d{2}$/.test(s)) return s;

    // parfois Sheets renvoie "dd/MM/yyyy" ou autre -> on tente parse
    const d = new Date(s);
    if(!isNaN(d.getTime())){
      return Utilities.formatDate(d, tz, "yyyy-MM-dd");
    }
    return ""; // invalide
  };

  const toHm_ = (v)=>{
    // ✅ corrige les heures stockées comme Date (30/12/1899 ...)
    if(v instanceof Date && !isNaN(v.getTime())){
      return Utilities.formatDate(v, tz, "HH:mm");
    }
    return String(v||"").trim();
  };

  const events = [];
  for(let r=1; r<values.length; r++){
    const row = values[r];
    const dateStr = toYmd_(row[iDate]);
    if(!dateStr) continue;

    // filtre année
    const y = Number(String(dateStr).slice(0,4));
    if(y !== Number(year)) continue;

    const title = String(row[iTitle] || "").trim();
    if(!title) continue;

    const ev = {
      date: dateStr,
      title,
      start: (iStart !== -1) ? toHm_(row[iStart]) : "",
      end: (iEnd !== -1) ? toHm_(row[iEnd]) : "",
      category: (iCat !== -1) ? String(row[iCat] || "").trim() : "",
      details: (iDetails !== -1) ? String(row[iDetails] || "").trim() : "",
      location: (iLoc !== -1) ? String(row[iLoc] || "").trim() : ""
    };

    if(iEventId !== -1){
      ev.event_id = String(row[iEventId] || "").trim();
    }

    events.push(ev);
  }

  const out = { ok:true, year, events, updatedAt:new Date().toISOString() };

  try{
    CacheService.getScriptCache().put(cacheKey, JSON.stringify(out), 60*10); // 10 min
  }catch(e){}

  return out;
}

/**
 * GET: ?view=planning_year_create&year=2027&email=...&callback=cb
 * admin requis
 */
function planningYearCreate_(e){
  const lock = LockService.getScriptLock();
  try{
    const ss = SpreadsheetApp.openById(SPREADSHEET_ID);

    const email = String(e?.parameter?.email || "").trim().toLowerCase();
    if(!email) return { ok:false, error:"email manquant" };

    const auth = authCheck_({ parameter:{ email } });
    if(!auth || auth.ok !== true || auth.role !== "admin"){
      return { ok:false, error:"Accès refusé (admin requis)" };
    }

    const year = Number(String(e?.parameter?.year || "").trim());
    if(!Number.isFinite(year) || year < 2000 || year > 2100){
      return { ok:false, error:"year invalide" };
    }

    lock.waitLock(15000);

    const sh = ss.getSheetByName(TAB_PLANNING_YEARS);
    if (!sh) return { ok:false, error:`Onglet introuvable: ${TAB_PLANNING_YEARS}` };

    const v = sh.getDataRange().getValues();
    const headers = (v[0] || []).map(h => normHeader_(h));
    const iYear = headers.indexOf("year");
    const iStatus = headers.indexOf("status");
    const iCreatedAt = headers.indexOf("created_at");
    const iCreatedBy = headers.indexOf("created_by");

    if (iYear === -1) return { ok:false, error:"Header manquant: year" };

    // déjà présent ?
    for(let r=1;r<v.length;r++){
